<Page x:Class="Calculation_of_optical_systems.OpticalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FB">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ОПИСАНИЕ -->
        <StackPanel Margin="0,0,0,20">

            <TextBlock FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap">
                Исходные значения подставляем в белую область.
                Результаты расчетов — желтая область.
                Углы: градусы + минуты. Пиксель — в угловых секундах.
            </TextBlock>

            <ComboBox Name="ModeBox"
                      SelectionChanged="ModeChanged"
                      Margin="0,15,0,0"
                      Height="32">

                <ComboBoxItem Content="1. Объектив" IsSelected="True"/>
                <ComboBoxItem Content="2. Пиксель"/>
                <ComboBoxItem Content="3. Найти Nh Nv"/>
                <ComboBoxItem Content="4. Найти Δh Δv"/>

            </ComboBox>

        </StackPanel>

        <!-- ОСНОВНОЙ БЛОК -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ВВОД -->
            <Border Background="White" CornerRadius="12" Padding="20">

                <StackPanel>

                    <!-- ===== РАЗРЕШЕНИЕ ===== -->
                    <StackPanel x:Name="ResolutionPanel" Margin="0,0,0,15">

                        <TextBlock Text="Разрешение"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <!-- Nh -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Nh"
                                       VerticalAlignment="Center"/>
                            <TextBox Name="NhBox"
                                     Grid.Column="1"
                                     TextChanged="InputChanged"/>
                            <TextBlock Text="пикс"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Nv -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Nv"
                                       VerticalAlignment="Center"/>
                            <TextBox Name="NvBox"
                                     Grid.Column="1"
                                     TextChanged="InputChanged"/>
                            <TextBlock Text="пикс"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>

                    <!-- ===== ПИКСЕЛЬ ===== -->
                    <StackPanel x:Name="PixelPanel" Margin="0,0,0,15">

                        <TextBlock Text="Размер пикселя"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <!-- Δh -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Δh"/>
                            <TextBox Name="DhBox"
                                     Grid.Column="1"
                                     TextChanged="InputChanged"/>
                            <TextBlock Text="мкм"
                                       Grid.Column="2"/>
                        </Grid>

                        <!-- Δv -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Δv"/>
                            <TextBox Name="DvBox"
                                     Grid.Column="1"
                                     TextChanged="InputChanged"/>
                            <TextBlock Text="мкм"
                                       Grid.Column="2"/>
                        </Grid>

                    </StackPanel>

                    <!-- ===== УГЛЫ ===== -->
                    <StackPanel x:Name="AnglePanel" Margin="0,0,0,15">

                        <TextBlock Text="Углы"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <!-- δh -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="δh"/>
                            <TextBox Name="AngleHBox"
                                     Grid.Column="1"
                                     TextChanged="InputChanged"/>
                            <TextBlock Text="°"
                                       Grid.Column="2"/>
                        </Grid>

                        <!-- δv -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="δv"/>
                            <TextBox Name="AngleVBox"
                                     Grid.Column="1"
                                     TextChanged="InputChanged"/>
                            <TextBlock Text="°"
                                       Grid.Column="2"/>
                        </Grid>

                    </StackPanel>

                    <!-- ===== ФОКУС ===== -->
                    <StackPanel>

                        <TextBlock Text="Фокус"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="f"/>
                            <TextBox Name="FBox"
                                     Grid.Column="1"
                                     TextChanged="InputChanged"/>
                            <TextBlock Text="мм"
                                       Grid.Column="2"/>
                        </Grid>

                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- РЕЗУЛЬТАТ -->
            <Border Grid.Column="1"
                    Margin="20,0,0,0"
                    Background="#FFFBE6"
                    CornerRadius="12"
                    Padding="20">

                <ScrollViewer>
                    <StackPanel Name="ResultPanel"/>
                </ScrollViewer>

            </Border>

        </Grid>
    </Grid>
</Page>