<Page x:Class="Calculation_of_optical_systems.OpticalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FB">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock
            Text="Расчет углов поля зрения объектива (ОБ)
Трактовка: целая часть — градусы, дробная часть — минуты.
Углы поля зрения пиксела отображаются в угловых секундах."
            TextWrapping="Wrap"
            FontSize="18"
            FontWeight="SemiBold"
            Margin="0,0,0,25"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="14"
                    Padding="25">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="2"
                                      Opacity="0.18"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Исходные данные"
                               FontSize="19"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <!-- Nh -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,14">
                        <TextBlock Text="Nh — количество пикселей по горизонтали"
                                   Margin="0,0,0,4"/>
                        <TextBox Name="NhBox"
                                 Height="32"
                                 Padding="6"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                    <!-- Nv -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,14">
                        <TextBlock Text="Nv — количество пикселей по вертикали"
                                   Margin="0,0,0,4"/>
                        <TextBox Name="NvBox"
                                 Height="32"
                                 Padding="6"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                    <!-- Δh -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,14">
                        <TextBlock Text="Δh — размер пикселя по горизонтали (мкм)"
                                   Margin="0,0,0,4"/>
                        <TextBox Name="DhBox"
                                 Height="32"
                                 Padding="6"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                    <!-- Δv -->
                    <StackPanel Grid.Row="4" Margin="0,0,0,14">
                        <TextBlock Text="Δv — размер пикселя по вертикали (мкм)"
                                   Margin="0,0,0,4"/>
                        <TextBox Name="DvBox"
                                 Height="32"
                                 Padding="6"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                    <!-- f -->
                    <StackPanel Grid.Row="5">
                        <TextBlock Text="f — фокусное расстояние объектива (мм)"
                                   Margin="0,0,0,4"/>
                        <TextBox Name="FBox"
                                 Height="32"
                                 Padding="6"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                </Grid>
            </Border>


            <Border Grid.Column="1"
                    Margin="25,0,0,0"
                    Background="White"
                    CornerRadius="14"
                    Padding="25">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="2"
                                      Opacity="0.18"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="ResultPanel"/>
                </ScrollViewer>

            </Border>

        </Grid>
    </Grid>
</Page>