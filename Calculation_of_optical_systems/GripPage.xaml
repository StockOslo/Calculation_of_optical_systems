<Page x:Class="Calculation_of_optical_systems.GripPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FB">

    <Page.Resources>

        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#F8FAFF"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock
            Text="Расчет глубины резкости изображаемого пространства (ГРИП)"
            FontSize="20"
            FontWeight="SemiBold"
            Margin="0,0,0,25"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="14"
                    Padding="25">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="2"
                                      Opacity="0.18"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="Исходные данные"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,18"/>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="R"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="дистанция фокусировки"
                                   FontSize="12"
                                   Foreground="#6B7280"/>
                        <TextBlock Text="м"
                                   FontSize="12"
                                   Foreground="#9CA3AF"
                                   Margin="0,0,0,5"/>
                        <TextBox Name="RBox"
                                 Style="{StaticResource ModernInput}"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,14" >
                        <TextBlock Text="f"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="фокусное расстояние"
                                   FontSize="12"
                                   Foreground="#6B7280"/>
                        <TextBlock Text="мм"
                                   FontSize="12"
                                   Foreground="#9CA3AF"
                                   Margin="0,0,0,5"/>
                        <TextBox Name="FBox"
                                 Style="{StaticResource ModernInput}"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="z"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="кружок нерезкости"
                                   FontSize="12"
                                   Foreground="#6B7280"/>
                        <TextBlock Text="мкм"
                                   FontSize="12"
                                   Foreground="#9CA3AF"
                                   Margin="0,0,0,5"/>
                        <TextBox Name="ZBox"
                                 Style="{StaticResource ModernInput}"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="K"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="диафрагменное число"
                                   FontSize="12"
                                   Foreground="#6B7280"/>
                        <TextBlock Text=""
                                   FontSize="12"
                                   Foreground="#9CA3AF"
                                   Margin="0,0,0,5"/>
                        <TextBox Name="KBox"
                                 Style="{StaticResource ModernInput}"
                                 TextChanged="InputChanged"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="25,0,0,0"
                    Background="White"
                    CornerRadius="14"
                    Padding="25">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="2"
                                      Opacity="0.18"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="Результаты"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <TextBlock Name="HResult" FontSize="16" Margin="0,6"/>
                    <TextBlock Name="R1Result" FontSize="16" Margin="0,6"/>
                    <TextBlock Name="R2Result" FontSize="16" Margin="0,6"/>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Page>