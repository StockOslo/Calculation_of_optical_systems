<Page x:Class="Calculation_of_optical_systems.LensesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FB">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХ -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Подбор объективов"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- ИСТОЧНИК -->
            <ComboBox Name="SourceBox"
                      Grid.Column="1"
                      Width="150"
                      Height="30">
                <ComboBoxItem Content="cctv" IsSelected="True"/>
                <ComboBoxItem Content="cameralab"/>
                <ComboBoxItem Content="azimp"/>
            </ComboBox>
        </Grid>

        <!-- ФИЛЬТРЫ -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                Padding="24">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Сенсор -->
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Формат матрицы"/>
                        <TextBox Name="SensorBox" Width="140" Height="30"/>
                    </StackPanel>

                    <!-- Фокус -->
                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="Фокус (мм)"/>
                        <TextBox Name="FocalBox" Width="140" Height="30"/>
                    </StackPanel>

                    <!-- Категория -->
                    <StackPanel Grid.Column="2" Margin="0,0,20,0">
                        <TextBlock Text="Категория"/>
                        <ComboBox Name="CategoryBox" Width="140" Height="30">
                            <ComboBoxItem Content=""/>
                            <ComboBoxItem Content="Фикс"/>
                            <ComboBoxItem Content="Вариофокал"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Кнопка -->
                    <Button Grid.Column="3"
                            Name="SearchButton"
                            Content="Подобрать"
                            Width="120"
                            Height="30"
                            VerticalAlignment="Bottom"
                            Click="ApplyFilter"/>

                    <!-- Статус -->
                    <TextBlock Grid.Column="4"
                               Name="StatusText"
                               Margin="10,0,0,0"
                               VerticalAlignment="Bottom"
                               FontWeight="SemiBold"/>
                </Grid>
            </Grid>
        </Border>

        <!-- СПИСОК -->
        <ScrollViewer Grid.Row="1" Margin="0,120,0,0">
            <WrapPanel Name="LensPanel"/>
        </ScrollViewer>

    </Grid>
</Page>