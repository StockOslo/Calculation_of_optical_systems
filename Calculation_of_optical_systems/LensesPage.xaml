<Page x:Class="Calculation_of_optical_systems.LensesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FB">

    <Grid Margin="25">

        <!-- строки -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <!-- верх -->

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Подбор объективов"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- источник -->
            <ComboBox Name="SourceBox"
                      Grid.Column="1"
                      Width="160"
                      Height="30"
                      VerticalAlignment="Center">
                <ComboBoxItem Content="cctv" IsSelected="True"/>
                <ComboBoxItem Content="cameralab"/>
                <ComboBoxItem Content="azimp"/>
            </ComboBox>
        </Grid>

        
        <!-- фильтры -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                Padding="20"
                Margin="0,0,0,15">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="2"
                                  Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Сенсор -->
                <StackPanel x:Name="SensorPanel" Margin="0,0,20,0">
                    <TextBlock Text="Формат матрицы"/>
                    <TextBox Name="SensorBox" Width="140" Height="30"/>
                </StackPanel>

                <!-- Фокус -->
                <StackPanel x:Name="FocalPanel" Grid.Column="1" Margin="0,0,20,0">
                    <TextBlock Text="Фокус (мм)"/>
                    <TextBox Name="FocalBox" Width="140" Height="30"/>
                </StackPanel>

                <!-- Категория -->
                <StackPanel x:Name="CategoryPanel" Grid.Column="2" Margin="0,0,20,0">
                    <TextBlock Text="Категория"/>
                    <ComboBox Name="CategoryBox" Width="140" Height="30">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Фикс"/>
                        <ComboBoxItem Content="Вариофокал"/>
                    </ComboBox>
                </StackPanel>

                <!-- Кнопка -->
                <Button Grid.Column="3"
                        Name="SearchButton"
                        Content="Подобрать"
                        Width="130"
                        Height="32"
                        VerticalAlignment="Bottom"
                        Background="#4F6DFF"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ApplyFilter"/>

                <!-- Статус -->
                <TextBlock Grid.Column="4"
                           Name="StatusText"
                           Margin="15,0,0,0"
                           VerticalAlignment="Bottom"
                           FontWeight="SemiBold"/>
            </Grid>
        </Border>

       
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">

            <WrapPanel Name="LensPanel"
                       Margin="0,10,0,0"/>
        </ScrollViewer>

    </Grid>
</Page>