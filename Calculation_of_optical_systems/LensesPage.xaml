<Page x:Class="Calculation_of_optical_systems.LensesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FB">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХ -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Подбор объективов"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <ComboBox Name="SourceBox"
                      Grid.Column="1"
                      Width="160"
                      Height="30"
                      SelectionChanged="SourceChanged">
                <ComboBoxItem Content="cctv" IsSelected="True"/>
                <ComboBoxItem Content="cameralab"/>
                <ComboBoxItem Content="azimp"/>
            </ComboBox>
        </Grid>

        <!-- ФИЛЬТРЫ -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                Padding="20"
                Margin="0,0,0,15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- sensor -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- focal -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- category -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- azimp -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- button -->
                    <ColumnDefinition Width="*"/>
                    <!-- status -->
                </Grid.ColumnDefinitions>

                <!-- SENSOR -->
                <StackPanel x:Name="SensorPanel" Margin="0,0,20,0">
                    <TextBlock Text="Формат матрицы"/>
                    <TextBox Name="SensorBox" FontSize="10" Width="140" Height="30"/>
                </StackPanel>

                <!-- FOCAL -->
                <StackPanel x:Name="FocalPanel" Grid.Column="1" Margin="0,0,20,0">
                    <TextBlock Text="Фокус (мм)"/>
                    <TextBox Name="FocalBox" FontSize="10" Width="140" Height="30"/>
                </StackPanel>

                <!-- CATEGORY -->
                <StackPanel x:Name="CategoryPanel" Grid.Column="2" Margin="0,0,20,0">
                    <TextBlock Text="Категория"/>
                    <ComboBox Name="CategoryBox" Width="140" Height="30">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Фикс"/>
                        <ComboBoxItem Content="Вариофокал"/>
                    </ComboBox>
                </StackPanel>

                <!-- AZIMP (отдельная колонка!) -->
                <StackPanel x:Name="AzimpPanel"
                            Grid.Column="3"
                            Margin="0,0,20,0"
                            Visibility="Collapsed">

                    <TextBlock Text="Фокус (мм)"/>
                    <TextBox Name="AzimpFocalBox" Width="140" FontSize="10" Height="30" Margin="0,0,0,5"/>

                    <TextBlock Text="ИК фильтр"/>
                    <ComboBox Name="AzimpIrComboBox" Width="140" Height="30" Margin="0,0,0,5"/>

                    <TextBlock Text="Поиск"/>
                    <TextBox Name="AzimpSearchBox" Width="140" FontSize="10" Height="30"/>

                </StackPanel>

                <!-- BUTTON -->
                <Button Grid.Column="4"
                        Content="Подобрать"
                        Width="130"
                        Height="32"
                        Click="ApplyFilter"/>

                <!-- STATUS -->
                <TextBlock Grid.Column="5"
                           Name="StatusText"
                           Margin="10,0,0,0"
                           VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- СПИСОК -->
        <ScrollViewer Grid.Row="2">
            <WrapPanel Name="LensPanel"/>
        </ScrollViewer>

    </Grid>
</Page>