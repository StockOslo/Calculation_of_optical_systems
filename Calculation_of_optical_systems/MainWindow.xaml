<Window x:Class="Calculation_of_optical_systems.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оптические системы" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="ParseButton" 
                    Content="Загрузить объективы с сайта" 
                    Click="ParseButton_Click"
                    Height="30" Width="200"/>
            <ListBox x:Name="LensesListBox" Margin="0,20,0,0" Height="300" Width="500"/>
        </StackPanel>
    </Grid>
</Window>